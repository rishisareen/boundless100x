{% endif %}

<div class="card" style="overflow-x: auto;">
  {% set companies = comparison.get('companies', {}) %}
  {% set ranks = comparison.get('ranks', {}) %}
  {% set total = companies|length %}
  <table>
    <thead>
      <tr>
        <th>Metric</th>
        {% for t in companies %}
        <th {% if t == ticker %}style="background: var(--thesis-bg); font-weight: 700;"{% endif %}>
          {{ t }}{% if t == ticker %} &#9733;{% endif %}
          {% if t != ticker and peer_categories %}
          {% if peer_categories.get(t) == 'benchmark' %}
          <br><span style="font-size: 0.7em; font-weight: 400; color: var(--amber);">BENCHMARK</span>
          {% elif peer_categories.get(t) == 'competitor' %}
          <br><span style="font-size: 0.7em; font-weight: 400; color: var(--green);">COMPETITOR</span>
          {% endif %}
          {% endif %}
        </th>
        {% endfor %}
      </tr>
    </thead>
    <tbody>
      {% set current_category = namespace(val='') %}
      {% for mid, label, category in peer_display_metrics %}
      {% if category != current_category.val %}
      {% set current_category.val = category %}
      <tr class="peer-category-row">
        <td colspan="{{ companies|length + 1 }}">{{ category }}</td>
      </tr>
      {% endif %}
      {% if mid in comparison.get('metrics', []) %}
      <tr>
        <td>{{ label }}</td>
        {% for t in companies %}
        {% set val = companies[t].get(mid) %}
        {% set rank = ranks.get(t, {}).get(mid) %}
        <td class="{% if rank == 1 %}rank-1{% elif rank == total %}rank-last{% endif %}" {% if t == ticker and rank != 1 and rank != total %}style="background: var(--thesis-bg);"{% endif %}>
          {% if val is not none %}{{ "%.2f"|format(val) }}{% else %}—{% endif %}
        </td>
        {% endfor %}
      </tr>
      {% endif %}
      {% endfor %}
    </tbody>
  </table>
  <p style="margin-top: 10px; color: var(--gray); font-size: 0.85em;">
    &#9733; Target company.
    <span style="color: var(--green);">Green</span> = best in class,
    <span style="color: var(--red);">Red</span> = worst in class.
    {% if peer_categories %}
    | <span style="color: var(--green);">COMPETITOR</span> = direct peer,
    <span style="color: var(--amber);">BENCHMARK</span> = sector reference only.
    {% endif %}
  </p>
</div>
{% endif %}


<!-- ═══════════════════════════════════════════════════════ -->
<!-- SECTION 10: Appendix                                   -->
<!-- ═══════════════════════════════════════════════════════ -->
<div id="appendix"></div>
<h2>Appendix</h2>

{# 10-Year Financial Snapshot #}
{% if snapshot %}
<div class="card snapshot-container">
  <h3 style="margin-top: 0;">10-Year Financial Snapshot</h3>
  {% set trends = snapshot[0].get('_trends', {}) if snapshot else {} %}
  <table class="snapshot-table" style="width: 100%; border-collapse: collapse;">
    <thead>
      <tr>
        <th style="text-align: left;">Metric</th>
        {% for row in snapshot %}
        <th>{{ row.year | replace("Mar ", "'") }}</th>
        {% endfor %}
        <th style="min-width: 40px;">3yr</th>
      </tr>
    </thead>
    <tbody>
      {% set snap_metrics = [
        ('revenue', 'Revenue (₹Cr)', 'comma', none),
        ('pat', 'PAT (₹Cr)', 'comma', none),
        ('eps', 'EPS (₹)', 'decimal', none),
        ('opm', 'OPM %', 'pct', [20, 10]),
        ('roce', 'RoCE %', 'pct', [20, 12]),
        ('de', 'D/E', 'de', [0.3, 1.0]),
        ('cfo', 'CFO (₹Cr)', 'cfo', none)
      ] %}
      {% for key, label, fmt, thresholds in snap_metrics %}
      <tr>
        <td>{{ label }}</td>
        {% for row in snapshot %}
        {% set val = row.get(key) %}
        <td{% if thresholds and val is not none %} class="{% if fmt == 'pct' %}{% if val >= thresholds[0] %}val-good{% elif val >= thresholds[1] %}val-warn{% else %}val-bad{% endif %}{% elif fmt == 'de' %}{% if val <= thresholds[0] %}val-good{% elif val <= thresholds[1] %}val-warn{% else %}val-bad{% endif %}{% endif %}"{% elif fmt == 'cfo' and val is not none %} class="{% if val > 0 %}val-good{% else %}val-bad{% endif %}"{% endif %}>
          {% if val is not none %}{% if fmt == 'comma' or fmt == 'cfo' %}{{ "{:,.0f}".format(val) }}{% elif fmt == 'decimal' %}{{ "%.2f"|format(val) }}{% elif fmt == 'pct' %}{{ "%.0f"|format(val) }}%{% elif fmt == 'de' %}{{ "%.2f"|format(val) }}x{% endif %}{% else %}—{% endif %}
        </td>
        {% endfor %}
        <td style="text-align: center; font-size: 1.1em;">
          {% set t = trends.get(key) %}
          {% if t == 'up' %}<span style="color: var(--green);">&#9650;</span>
          {% elif t == 'down' %}<span style="color: var(--red);">&#9660;</span>
          {% elif t == 'flat' %}<span style="color: var(--gray);">&#9644;</span>
          {% else %}—{% endif %}
        </td>
      </tr>
      {% endfor %}
    </tbody>
  </table>
  <p style="margin-top: 8px; color: var(--text-muted); font-size: 0.75em;">
    3yr column: <span style="color: var(--green);">&#9650;</span> improving &gt;5% | <span style="color: var(--red);">&#9660;</span> declining &gt;5% | <span style="color: var(--gray);">&#9644;</span> stable. D/E: lower is better.
  </p>
</div>
{% endif %}

{# All Signals #}
<div class="card" style="margin-top: 15px;">
  <h3 style="margin-top: 0;">All Signals</h3>
  {% set good_flags = [] %}
  {% set bad_flags = [] %}
  {% set neutral_flags = [] %}
  {% for f in flags %}
    {% if f.sentiment == 'good' %}{% if good_flags.append(f) %}{% endif %}
    {% elif f.sentiment == 'bad' %}{% if bad_flags.append(f) %}{% endif %}
    {% else %}{% if neutral_flags.append(f) %}{% endif %}
    {% endif %}
  {% endfor %}

  {% if good_flags %}
  <div class="signal-group">
    <div class="signal-group-label" style="color: var(--green);">Strengths</div>
    {% for f in good_flags %}
    <span class="flag flag-good"><span class="flag-icon">&#10003;</span> {{ f.label }}</span>
    {% endfor %}
  </div>
  {% endif %}

  {% if bad_flags %}
  <div class="signal-group">
    <div class="signal-group-label" style="color: var(--red);">Concerns</div>
    {% for f in bad_flags %}
    <span class="flag flag-bad"><span class="flag-icon">&#10007;</span> {{ f.label }}</span>
    {% endfor %}
  </div>
  {% endif %}

  {% if neutral_flags %}
  <div class="signal-group">
    <div class="signal-group-label">Context</div>
    {% for f in neutral_flags %}
    <span class="flag"><span class="flag-icon">&#8226;</span> {{ f.label }}</span>
    {% endfor %}
  </div>
  {% endif %}
</div>

{# Warnings & Errors #}
{% if errors %}
<div class="card" style="margin-top: 15px;">
  <h3 style="margin-top: 0; color: var(--red);">Warnings &amp; Errors</h3>
  {% for e in errors %}
  <p style="color: var(--red);">{{ e }}</p>
  {% endfor %}
</div>
{% endif %}

<!-- Footer -->
<div class="footer">
  Generated by Boundless100x SQGLP Research System | {{ generation_date }}
</div>

</div>

<script>
function toggleTheme() {
  const html = document.documentElement;
  const current = html.getAttribute('data-theme');
  const next = current === 'dark' ? 'light' : 'dark';
  html.setAttribute('data-theme', next);
  try { localStorage.setItem('sqglp-theme', next); } catch(e) {}
}
(function() {
  try {
    const saved = localStorage.getItem('sqglp-theme');
    if (saved === 'dark') document.documentElement.setAttribute('data-theme', 'dark');
  } catch(e) {}
})();
</script>
</body>
</html>
