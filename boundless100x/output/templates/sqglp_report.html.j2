{# Shareholding Trend — absorbed into QM #}
{% if shareholding_data %}
<div class="card snapshot-container" style="margin-top: 15px;">
  <h3 style="margin-top: 0;">Shareholding Trend</h3>
  <table class="snapshot-table" style="width: 100%; border-collapse: collapse;">
    <thead>
      <tr>
        <th style="text-align: left;">Category</th>
        {% for sh in shareholding_data %}
        <th>{{ sh.quarter | replace("Mar ", "M'") | replace("Jun ", "J'") | replace("Sep ", "S'") | replace("Dec ", "D'") }}</th>
        {% endfor %}
        <th style="font-weight: 700;">Chg</th>
      </tr>
    </thead>
    <tbody>
      {% set sh_rows = [('promoter_pct', 'Promoter'), ('fii_pct', 'FII'), ('dii_pct', 'DII'), ('public_pct', 'Public')] %}
      {% for col, label in sh_rows %}
      {% set first_val = shareholding_data[0].get(col) %}
      {% set last_val = shareholding_data[-1].get(col) %}
      {% set delta = (last_val - first_val) if first_val is not none and last_val is not none else none %}
      <tr>
        <td style="font-weight: 600;">{{ label }}</td>
        {% for sh in shareholding_data %}
        {% set val = sh.get(col) %}
        <td style="text-align: right;">{% if val is not none %}{{ "%.1f"|format(val) }}{% else %}—{% endif %}</td>
        {% endfor %}
        <td style="text-align: right; font-weight: 700; color: {% if delta is not none and delta > 0.5 %}var(--green){% elif delta is not none and delta < -0.5 %}var(--red){% else %}var(--gray){% endif %};">
          {% if delta is not none %}{{ "%+.1f"|format(delta) }}pp{% else %}—{% endif %}
        </td>
      </tr>
      {% endfor %}
      {% if shareholding_data[0].get('govt_pct') is not none %}
      {% set first_govt = shareholding_data[0].get('govt_pct') %}
      {% set last_govt = shareholding_data[-1].get('govt_pct') %}
      {% set delta_govt = (last_govt - first_govt) if first_govt is not none and last_govt is not none else none %}
      <tr>
        <td style="font-weight: 600;">Government</td>
        {% for sh in shareholding_data %}
        {% set val = sh.get('govt_pct') %}
        <td style="text-align: right;">{% if val is not none %}{{ "%.1f"|format(val) }}{% else %}—{% endif %}</td>
        {% endfor %}
        <td style="text-align: right; font-weight: 700; color: {% if delta_govt is not none and delta_govt > 0.5 %}var(--green){% elif delta_govt is not none and delta_govt < -0.5 %}var(--red){% else %}var(--gray){% endif %};">
          {% if delta_govt is not none %}{{ "%+.1f"|format(delta_govt) }}pp{% else %}—{% endif %}
        </td>
      </tr>
      {% endif %}
      {% if shareholding_data[0].get('promoter_pledge_pct') is not none %}
      {% set first_pledge = shareholding_data[0].get('promoter_pledge_pct') %}
      {% set last_pledge = shareholding_data[-1].get('promoter_pledge_pct') %}
      {% set delta_pledge = (last_pledge - first_pledge) if first_pledge is not none and last_pledge is not none else none %}
      <tr>
        <td style="font-weight: 600; color: var(--red);">Pledge %</td>
        {% for sh in shareholding_data %}
        {% set val = sh.get('promoter_pledge_pct') %}
        <td style="text-align: right; color: {% if val is not none and val > 0 %}var(--red){% else %}var(--gray){% endif %};">{% if val is not none %}{{ "%.1f"|format(val) }}{% else %}—{% endif %}</td>
        {% endfor %}
        <td style="text-align: right; font-weight: 700; color: {% if delta_pledge is not none and delta_pledge > 0.5 %}var(--red){% elif delta_pledge is not none and delta_pledge < -0.5 %}var(--green){% else %}var(--gray){% endif %};">
          {% if delta_pledge is not none %}{{ "%+.1f"|format(delta_pledge) }}pp{% else %}—{% endif %}
        </td>
      </tr>
      {% endif %}
    </tbody>
  </table>
</div>
{% endif %}


